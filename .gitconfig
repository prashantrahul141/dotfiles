[core]
  editor = nvim
	excludesfile = /home/prashant/.gitignore_global

[color "diff"]
  whitespace = red reverse

[init]
  defaultBranch = main

[user]
  email = prashantrahul141@protonmail.com
  name = Prashant
  signingkey = prashantrahul141@protonmail.com

[credential "https://github.com"]
  helper = !/usr/bin/gh auth git-credential

[credential "https://gist.github.com"]
  helper = !/usr/bin/gh auth git-credential

[commit]
  gpgsign = true

[tag]
  gpgSign = true

[rerer]
  enabled = true

[maintenance]
  auto = false
  strategy = incremental

[merge]
  conflictStyle = diff3
